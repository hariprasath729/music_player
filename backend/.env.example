# ------------------------------------------------------------------------------
# Music Player Backend Environment Configuration Example
# Rename this file to '.env' and fill in your actual production/dev values.
# NEVER commit the actual '.env' file to source control.
# ------------------------------------------------------------------------------

# App Environment
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
APP_URL=https://your-backend-url.onrender.com

# Allowed CORS Origins (comma-separated list)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Security - Cryptographically Secure JWT Secret
# Minimum 32 characters (64+ hexadecimal characters recommended).
# Generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_cryptographically_secure_random_hex_jwt_secret_64_characters_long

# Hashing & Authentication Default Configuration
BCRYPT_ROUNDS=12
COOKIE_AUTH_ENABLED=false

# Database Configuration
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/database

# Database Protection Configuration
MAX_QUERY_TIME_MS=5000
MAX_PAGE_SIZE=100

# Email SMTP Provider Configuration (e.g. Brevo)
BREVO_HOST=smtp-relay.brevo.com
BREVO_PORT=587
BREVO_EMAIL=your_smtp_user_email@smtp-brevo.com
BREVO_SMTP_KEY=your_brevo_smtp_key_xsmtpsib-...
MAIL_FROM_NAME=Music Player
MAIL_FROM_EMAIL=no-reply@yourdomain.com
ADMIN_EMAIL=your_admin_email@gmail.com


# Cloudflare Turnstile / CAPTCHA Integration (Optional)
# If provided, the backend will verify captcha response on registration/login.
TURNSTILE_SECRET=your_cloudflare_turnstile_secret_key

# Download Protection Limits
MAX_DOWNLOADS_PER_HOUR=50
MAX_DOWNLOADS_PER_IP_HOUR=100
